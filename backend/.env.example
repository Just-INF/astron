LEMONSQUEEZY_TABLE_VARIANT_ID=
LEMONSQUEEZY_GROUP_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Nora AI (the free model may work without an API key)
NORA_AI_URL=https://opencode.ai/zen/v1/chat/completions

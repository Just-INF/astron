{
  "name": "astron-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun run db:migrate && bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:seed": "bun src/db/seed.ts",
    "validate:production-env": "bun src/scripts/validate-production-env.ts",
    "billing:reconcile": "bun src/scripts/reconcile-billing.ts",
    "email:failures": "bun src/scripts/email-jobs.ts list",
    "email:retry": "bun src/scripts/email-jobs.ts retry",
    "media:cleanup": "bun src/scripts/cleanup-media.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.2",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.4",
    "luxon": "^3.7.1",
    "nodemailer": "^9.0.3",
    "postgres": "^3.4.7",
    "redis": "^6.1.0",
    "sharp": "^0.35.3",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/bun": "^1.2.18",
    "@types/luxon": "^3.6.2",
    "@types/nodemailer": "^8.0.1",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.8.3"
  }
}

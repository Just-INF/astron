# Dependencies and build output
node_modules/
**/node_modules/
dist/
**/dist/
coverage/

# Local configuration and runtime data
.env
.env.*
!.env.example
backend/.data/
backend/files/*
!backend/files/.gitkeep
*.log
*.tsbuildinfo

# Local export archive
frontend.rar

# Local visual QA artifacts
frontend/.playwright-mcp/
frontend/vite.err
frontend/layout-editor-fix.png

# Generated/legacy docs are ignored, but the maintained Markdown reference is versioned.
docs/*
!docs/reference/
!docs/reference/**
# The rebuilt static documentation website is source-controlled.
olddocs/*
!olddocs/build.mjs
!olddocs/index.html
!olddocs/*.html
!olddocs/assets/
!olddocs/assets/**
